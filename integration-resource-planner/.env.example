DB_WRITER_HOST=your-writer-db-host
DB_READER_HOST=your-reader-db-host
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
API_PORT=3000
API_HOST=0.0.0.0
JWT_SECRET=change_this_secret_for_production
JWT_EXPIRES_IN=8h
LDAP_URL=ldaps://your-ad-server.utility.pge.com:636
LDAP_BASE_DN=DC=utility,DC=pge,DC=com
LDAP_DOMAIN=utility.pge.com
LDAP_SERVICE_DN=CN=svc_ldap_bind,OU=Service Accounts,DC=utility,DC=pge,DC=com
LDAP_SERVICE_PASSWORD=your_service_account_password
LDAP_USER_SEARCH_FILTER=(&(objectCategory=person)(objectClass=user)(|(sAMAccountName={{username}})(userPrincipalName={{username}})))
MULESOFT_CLIENT_ID=your_mulesoft_client_id
MULESOFT_CLIENT_SECRET=your_mulesoft_client_secret
MULESOFT_TOKEN_URL=https://anypoint.mulesoft.com/accounts/api/v2/oauth2/token